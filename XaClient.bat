@echo off
setlocal enabledelayedexpansion
title XaClient Launcher

set "REPO=Xani4kaGitHub/XaClient"
set "MODS=%APPDATA%\.minecraft\mods"
if not exist "%MODS%" mkdir "%MODS%"

:: Enable ANSI Escape Codes
for /F %%a in ('echo prompt $E ^| cmd') do set "ESC=%%a"

cls
echo.
echo %ESC%[95m____  ___      _________ .__  .__               __
echo \   \/  /____  \_   ___ \^|  ^| ^|__^| ____   _____/  ^|_
echo  \     /\__  \ /    \  \/^|  ^| ^|  ^|/ __ \ /    \   __\
echo  /     \ / __ \\     \___^|  ^|_^|  \  ___/^|   ^|  \  ^|
echo /___/\  (____  /\______  /____/__^|\___  ^>___^|  /__^|
echo       \_/    \/        \/             \/     \/     %ESC%[0m
echo.
echo  %ESC%[95m::%ESC%[97m Checking for updates...%ESC%[0m
echo.

powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand 

echo.
echo  %ESC%[95m[*]%ESC%[97m Launching Minecraft...%ESC%[0m
echo.
start "" "minecraft://"
echo  %ESC%[95m » %ESC%[97mIn the launcher pick the %ESC%[95mFabric 1.21.4%ESC%[97m profile and press Play.%ESC%[0m
echo.
pause
